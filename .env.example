# Copy this file to .env and fill in real values. .env is gitignored.

# === KernelAgent (kernel generator) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_MODEL=claude-sonnet-4-6        # KernelAgent reads OPENAI_MODEL as its default model name
NUM_KERNEL_SEEDS=4                     # parallel verification workers per problem (lower to 1 on Tier 1 rate limit)
MAX_REFINEMENT_ROUNDS=10               # max retries per worker before giving up

# === GPU pinning ===
# Default: verifier.gpu_pick.pin_freest_gpu() runs nvidia-smi and auto-picks
# the freest GPU at startup. Leave this UNSET for that behavior.
# Override: uncomment and set to a specific GPU index to force it (useful when
# you want to share specific cards or when auto-pick mis-detects).
# CUDA_VISIBLE_DEVICES=0

# === Our debate layer ===
DEBATE_MODEL=claude-sonnet-4-6         # model used by author / skeptic / judge
DEBATE_MAX_ROUNDS=4
